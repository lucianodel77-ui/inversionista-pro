{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/cafci.js":        { "maxDuration": 60 },
    "api/fci-history.js":  { "maxDuration": 30 },
    "api/fci-penultimo.js":{ "maxDuration": 15 },
    "api/chat.js":         { "maxDuration": 30 },
    "api/market.js":       { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/chat",          "destination": "/api/chat"          },
    { "source": "/api/cafci",         "destination": "/api/cafci"         },
    { "source": "/api/fci-history",   "destination": "/api/fci-history"   },
    { "source": "/api/fci-penultimo", "destination": "/api/fci-penultimo" },
    { "source": "/api/market",        "destination": "/api/market"        }
  ]
}
